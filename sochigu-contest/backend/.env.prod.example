NODE_ENV=production
PORT=3000

# Database — DB_HOST должен совпадать с именем сервиса в docker-compose.prod.yml
DB_HOST=postgres
DB_PORT=5432
DB_USER=sochigu
DB_PASS=ЗАМЕНИ_НА_СИЛЬНЫЙ_ПАРОЛЬ
DB_NAME=sochigu_contest

# Управление синхронизацией схемы БД:
# true  — таблицы создаются автоматически (только при первом деплое!)
# false — безопасный режим (после первого деплоя сменить на false)
DB_SYNCHRONIZE=true

# JWT — используй crypto.randomBytes(64).toString('hex') для генерации
JWT_SECRET=ЗАМЕНИ_НА_СИЛЬНЫЙ_СЕКРЕТ_64_БАЙТА
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=ЗАМЕНИ_НА_ДРУГОЙ_СИЛЬНЫЙ_СЕКРЕТ_64_БАЙТА
JWT_REFRESH_EXPIRES_IN=7d

# URL фронтенда (для CORS)
FRONTEND_URL=http://sgu.drach.pro:8890

# SMTP — заполни реальными данными или оставь пустым для отключения писем
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=noreply@example.com
SMTP_PASS=ЗАМЕНИ_НА_ПАРОЛЬ_SMTP

UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
